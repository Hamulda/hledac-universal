  "conflicts": [
    {
      "id": "C1",
      "severity": "HIGH",
      "title": "MLX wired limit inconsistency",
      "description": "core/__main__.py sets mx.metal.set_wired_limit(2_500_000_000) = 2.326 GiB. But utils/mlx_cache.py defines _METAL_WIRED_LIMIT_BYTES = 2_684_354_560 = 2.5 GiB. Two different values. The mlx_cache value is what gets used by _ensure_metal_memory_limits() which is called from resource_allocator.py cleanup path. The __main__.py value is set at boot before mlx_cache is configured.",
      "files": ["core/__main__.py:234", "utils/mlx_cache.py:171"],
      "values": [2500000000, 2684354560],
      "units": ["bytes", "bytes"],
      "conflict_group": "mlx_wired_limit"
    },
    {
      "id": "C2",
      "severity": "MEDIUM",
      "title": "RAM ceiling inconsistency — three different 5.5GB values",
      "description": "Three different components each define 5.5GB ceiling: (1) resource_allocator.py MAX_RAM_GB=5.5, (2) layers/layer_manager.py M1MemoryOptimizer(memory_limit_mb=5500), (3) fetching/public_fetcher.py rss_gb > 5.5 check. All 5.5GB but different types (GB vs MB, GiB implicit). No single canonical source.",
      "files": ["resource_allocator.py:75", "layers/layer_manager.py", "fetching/public_fetcher.py:1224"],
      "values": [5.5, 5500, 5.5],
      "units": ["GB", "MB", "GB"],
      "conflict_group": "ram_ceiling_fragmented"
    },
    {
      "id": "C3",
      "severity": "MEDIUM",
      "title": "UMA CRITICAL threshold vs M1 benchmark ceiling — same value",
      "description": "utils/uma_budget.py CRITICAL_THRESHOLD_MB=6656 and benchmarks/m1_sustained_sprint.py M1_8GB_CEILING_MB=6656 are identical but owned by different sprint eras. No guarantees they stay in sync. No canonical constant shared between them.",
      "files": ["utils/uma_budget.py", "benchmarks/m1_sustained_sprint.py:49"],
      "values": [6656, 6656],
      "units": ["MB", "MB"],
      "conflict_group": "uma_threshold_duplication"
    },
    {
      "id": "C4",
      "severity": "MEDIUM",
      "title": "ResourceAllocator.EMERGENCY_RAM_GB=6.2 vs uma_budget CRITICAL=6.5",
      "description": "resource_allocator.py defines EMERGENCY_RAM_GB=6.2 (triggers emergency brake/cancellation). But uma_budget.py CRITICAL=6.5. The emergency threshold (6.2) is BELOW the critical threshold (6.5). This inversion means the resource_allocator emergency brake fires before the UmaState critical state is reached. Possible race condition or intentional gradation — unclear from code.",
      "files": ["resource_allocator.py:76", "utils/uma_budget.py"],
      "values": [6.2, 6.5],
      "units": ["GB", "GB"],
      "conflict_group": "emergency_threshold_inversion"
    },
    {
      "id": "C5",
      "severity": "LOW",
      "title": "high_water guard is 0.85 everywhere but computed differently",
      "description": "All 6+ RAM guard sites check high_water > 0.85, but some compute the actual RSS comparison differently: streaming_embedder compares rss_mb > high_water * 0.85; social_identity_miner compares rss_mb > high_water * 0.85; multimodal/analyzer.py uses governor.high_water * 0.85 on usage['ram_mb'] dict; runtime/resource_governor.py blocks if high_water > 0.85. The base high_water value (from uma_budget) is in MB; RSS can be in MB or GiB depending on source.",
      "files": ["intelligence/streaming_embedder.py:140", "intelligence/social_identity_miner.py:211", "multimodal/analyzer.py:434", "runtime/resource_governor.py:262", "layers/layer_manager.py"],
      "values": [0.85, 0.85, 0.85, 0.85, 0.85],
      "units": ["ratio", "ratio", "ratio", "ratio", "ratio"],
      "conflict_group": "ram_guard_threshold"
    },
    {
      "id": "C6",
      "severity": "LOW",
      "title": "configure_mlx_limits cache_limit default (1536) vs mlx_cache _METAL_CACHE_LIMIT (2684)",
      "description": "hermes3_engine.py calls configure_mlx_limits(cache_limit_mb=1536) for MLX model loading. But _ensure_metal_memory_limits() in mlx_cache.py sets _METAL_CACHE_LIMIT_BYTES=2684354560 (2.5GiB). These are the same logical parameter but with different values: 1536MB vs 2560MB.",
      "files": ["brain/hermes3_engine.py:1997", "utils/mlx_cache.py:171"],
      "values": [1536, 2560],
      "units": ["MB", "MB"],
      "conflict_group": "mlx_cache_limit"
    },
    {
      "id": "C7",
      "severity": "INFO",
      "title": "VLMAnalyzer 5.0GB threshold stands alone",
      "description": "tools/vlm_analyzer.py uses rss > 5.0 * 1024**3 for its skip check. This is different from the 5.5GB ceiling used everywhere else. It's an independent determination, not derived from any shared constant.",
      "files": ["tools/vlm_analyzer.py:112"],
      "values": [5120],
      "units": ["MB"],
      "conflict_group": "vlm_ram_guard"
    }
  ],

