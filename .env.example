# Hledac Universal — Environment Variables
# Copy to .env and fill in values

# Logging
HLEDAC_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# Memory (M1 8GB: stay below 6.25GB total)
HLEDAC_MEMORY_LIMIT_MB=8192  # Memory limit in MB

# Research mode (quick, standard, deep, extreme, autonomous)
HLEDAC_RESEARCH_MODE=standard

# Max steps per research session
HLEDAC_MAX_STEPS=100

# Offline mode (skip network fetches)
HLEDAC_OFFLINE=false

# Runtime mode (async, sync, etc.)
HLEDAC_RUNTIME_MODE=async

# Hermes LLM sustain mode
GHOST_HERMES_SUSTAIN=false

# MLX KV cache size (default 8192 for M1 8GB)
GHOST_KV_SIZE=8192

# F250: Dynamic windup ratio (fraction of sprint used for windup, 0.30 = 30%)
# Override with HLEDAC_WINDUP_LEAD_RATIO=0.30 to change short-sprint scaling
HLEDAC_WINDUP_LEAD_RATIO=0.30

# F254: Hermes3 pre-sprint memory threshold (GiB). Hermes3 4bit ≈ 2.2GB RSS.
# If available UMA < this value, Hermes3 load is deferred (lazy retry, max 2 attempts).
HLEDAC_HERMES_MIN_UMA_GB=2.5

# Prefix cache experiment
GHOST_PREFIX_CACHE_EXPERIMENT=false

# --- Operational (requires external setup) ---
# CI/CD: managed via GitHub Actions secrets
# Rollback: managed via git tags and deploy scripts
# Security scanning: run `bandit -r .` and `pip-audit` manually
# Secrets management: use pyzipper or external vault
# --- RL Feedback Loop (Sprint F223K) ---
# Set to true to activate quality-weighted source selection via RL feedback
ENABLE_RL_FEEDBACK=false

# --- Tor Proxy ---
# TOR proxy URL (default: socks5://127.0.0.1:9050)
TOR_PROXY_URL=socks5://127.0.0.1:9050

# --- I2P Proxy ---
# I2P SAM proxy URL (default: socks5://127.0.0.1:7654)
I2P_PROXY_URL=socks5://127.0.0.1:7654

# --- Chrome DevTools Protocol ---
# CDP endpoint for headless browser (default: ws://127.0.0.1:9222)
CDP_ENDPOINT=ws://127.0.0.1:9222

# --- Graph Real-Time Wire (Sprint F241) ---
# Set to true to write accepted findings to DuckPGQGraph on the write path (not just at teardown).
# Default: false (advisory-only, conservative). Requires GRAPH_REALTIME_WIRE=true to enable.
GRAPH_REALTIME_WIRE=false

# RL Production Config
HLEDAC_DISABLE_RL=  # prázdné = RL zapnuto (opt-out model)
HLEDAC_RL_EPSILON_FLOOR=0.1  # min exploration rate
HLEDAC_RL_TRAIN_EVERY=10  # train každých N sprintů

# Enable IPFS gateway queries (unindexed/archival data)
HLEDAC_ENABLE_IPFS=1

# --- F235: External Intelligence Lanes ---
# Shodan API key (device/IP fingerprints, banners, vulns)
# Free tier: 1 req/sec, register at https://account.shodan.io/
SHODAN_API_KEY=

# GreyNoise API key (mass scanner detection)
# Free tier: 60 queries/min, register at https://viz.greynoise.io/
# Alternative: use community API (no key needed) with use_community=True
GREYNOISE_API_KEY=

# Censys API credentials (certificate transparency, TLS banners)
# Free tier: 0.4 req/sec, register at https://search.censys.io/
CENSYS_API_ID=
CENSYS_API_SECRET=
