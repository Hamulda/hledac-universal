# ---------------------------------------------------------------------------
# Types
# ---------------------------------------------------------------------------

@dataclass
class WheelGateResult:
    """Result of a wheel gate run."""
    extras_requested: List[str]
    platform_tag: str
    pip_command: str
    dry_run: bool
    packages_by_extra: Dict[str, List[str]]
    executed: bool = False
    exit_code: int = 0
    error: str | None = None


# ---------------------------------------------------------------------------
# Core logic
# ---------------------------------------------------------------------------

def get_platform_tag() -> str:
    """Return the pip platform tag for cp314 macosx_arm64."""
    return "cp314-macosx_14_0_arm64"


def build_extra_packages(requested_extras: List[str]) -> Dict[str, List[str]]:
    """Group package names by extra for requested extras + default."""
    if "all" in requested_extras:
        requested_extras = [e for e in SUPPORTED_EXTRAS if e != "all"]
    if "default" not in requested_extras:
        requested_extras = ["default"] + requested_extras

    result: Dict[str, List[str]] = {}
    for pkg in WHEEL_REPORT_PACKAGES:
        if pkg["extra"] in requested_extras:
            result.setdefault(pkg["extra"], []).append(pkg["name"])

    return result


def build_pip_download_command(
    requested_extras: List[str],
    platform_tag: str,
    python_version: str = "314",
) -> str:
    """Build the pip download command for the given extras and platform."""
    if "all" in requested_extras:
        extras_list = [e for e in SUPPORTED_EXTRAS if e != "all"]
    else:
        extras_list = requested_extras if requested_extras else ["default"]

    extra_str = ",".join(sorted(set(extras_list)))
    # Build pip install command (no deps= only download)
    cmd = (
        f"pip download "
        f"--python-version {python_version} "
        f"--platform {platform_tag} "
        f"--only-binary :all: "
        f"--no-deps "
        f"-e .[{extra_str}] "
        f"--dest /tmp/hledac_wheels"
    )
    return cmd


def run_wheel_gate(
    requested_extras: List[str],
    dry_run: bool = True,
    execute: bool = False,
) -> WheelGateResult:
    """
    Main entry point for wheel gate.

    Returns WheelGateResult with pip command, package grouping, and execution status.
    """
    platform_tag = get_platform_tag()
    packages_by_extra = build_extra_packages(requested_extras)
    pip_cmd = build_pip_download_command(requested_extras, platform_tag)

    result = WheelGateResult(
        extras_requested=requested_extras,
        platform_tag=platform_tag,
        pip_command=pip_cmd,
        dry_run=dry_run,
        packages_by_extra=packages_by_extra,
    )

    if dry_run:
        # No network — just report
        result.executed = False
        result.exit_code = 0
        return result

    if not execute:
        print("ERROR: pip download not executed (--execute not provided)", file=sys.stderr)
        print("  Add --execute to run pip download.", file=sys.stderr)
        print(f"  Command that would run: {pip_cmd}", file=sys.stderr)
        result.exit_code = 1
        result.error = "execute flag not set"
        return result

    # Execute pip download
    print(f"[cp314_wheel_gate] Executing pip download for extras: {requested_extras}", file=sys.stderr)
    print(f"[cp314_wheel_gate] Platform: {platform_tag}", file=sys.stderr)
    print(f"[cp314_wheel_gate] Command: {pip_cmd}", file=sys.stderr)

    try:
        proc = subprocess.run(
            pip_cmd,
            shell=True,
            capture_output=True,
            text=True,
            timeout=300,
        )
        result.executed = True
        result.exit_code = proc.returncode
        if proc.returncode != 0:
            result.error = proc.stderr[:500]
            print(f"ERROR: pip download failed: {proc.stderr[:300]}", file=sys.stderr)
        else:
            print(f"[cp314_wheel_gate] pip download succeeded", file=sys.stderr)
    except Exception as e:
        result.executed = True
        result.exit_code = 3
        result.error = str(e)[:300]
        print(f"ERROR: pip download exception: {e}", file=sys.stderr)

    return result


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="cp314_wheel_gate.py",
        description="CPython 3.14 macOS ARM64 wheel validation gate",
        epilog="Exit codes: 0=success, 1=execute-blocked, 2=invalid extra, 3=pip-failed",
    )
    parser.add_argument(
        "--extra", "-e",
        action="append",
        default=[],
        dest="extras",
        metavar="EXTRA",
        choices=sorted(SUPPORTED_EXTRAS),
        help="Extra to include (default: all). Repeat for multiple.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        default=True,
        help="Default: do not run pip (dry-run mode)",
    )
    parser.add_argument(
        "--execute",
        action="store_true",
        default=False,
        help="REQUIRED to actually run pip download. Without this flag, dry-run only.",
    )
    parser.add_argument(
        "--output-json",
        metavar="PATH",
        help="Write wheel gate result as JSON to PATH",
    )
    parser.add_argument(
        "--python-version",
        default="314",
        metavar="VER",
        help="CPython version for platform tag (default: 314)",
    )
    return parser


def print_report(result: WheelGateResult, out=sys.stdout) -> None:
    """Print human-readable wheel gate report."""
    print(f"=== cp314 Wheel Gate Report ===", file=out)
    print(f"Requested extras : {result.extras_requested or ['default']}", file=out)
    print(f"Platform tag     : {result.platform_tag}", file=out)
    print(f"Dry-run          : {result.dry_run}", file=out)
    print(f"Executed         : {result.executed}", file=out)
    print(f"Exit code        : {result.exit_code}", file=out)
    if result.error:
        print(f"Error            : {result.error}", file=out)
    print(file=out)

    print("Packages by extra:", file=out)
    for extra, packages in sorted(result.packages_by_extra.items()):
        print(f"  [{extra}]", ", ".join(sorted(packages)), file=out)

    print(file=out)
    print(f"Pip command:", file=out)
    print(f"  {result.pip_command}", file=out)


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()

    # Validate extras
    invalid = set(args.extras) - SUPPORTED_EXTRAS
    if invalid:
        print(f"ERROR: unknown extra(s): {', '.join(sorted(invalid))}", file=sys.stderr)
        print(f"Supported: {', '.join(sorted(SUPPORTED_EXTRAS))}", file=sys.stderr)
        return 2

    requested = args.extras if args.extras else ["default"]
    result = run_wheel_gate(
        requested_extras=requested,
        dry_run=not args.execute,
        execute=args.execute,
    )

    # Output JSON if requested
    if args.output_json:
        payload = {
            "extras_requested": result.extras_requested,
            "platform_tag": result.platform_tag,
            "pip_command": result.pip_command,
            "dry_run": result.dry_run,
            "executed": result.executed,
            "exit_code": result.exit_code,
            "error": result.error,
            "packages_by_extra": result.packages_by_extra,
        }
        with open(args.output_json, "w") as f:
            json.dump(payload, f, indent=2)
        print(f"[cp314_wheel_gate] JSON written to {args.output_json}", file=sys.stderr)

    # Always print human-readable report to stdout (only on success)
    if result.exit_code == 0 or result.dry_run:
        print_report(result)

    return result.exit_code


if __name__ == "__main__":
    sys.exit(main())