#!/usr/bin/env python3
"""
cp314_wheel_gate.py — CPython 3.14 wheel validation gate
========================================================

Sprint F207N-B: Build Truth

Purpose:
  Construct and optionally execute pip download commands for cp314 macosx_arm64
  wheels. Reports package groupings by extra without installing anything.

No network by default. --execute explicitly required to run pip download.

Usage:
  # Dry-run (default, no network):
  python tools/cp314_wheel_gate.py

  # Dry-run for specific extra:
  python tools/cp314_wheel_gate.py --extra apple-accel

  # JSON output dry-run:
  python tools/cp314_wheel_gate.py --extra osint-html --output-json wheels.json

  # Execute pip download (EXPLICIT --execute required):
  python tools/cp314_wheel_gate.py --extra all --execute

  # Multi-extra:
  python tools/cp314_wheel_gate.py --extra light --extra apple-accel

Exit codes:
  0  — dry-run completed (no network activity)
  0  — execute completed successfully
  1  — execute not permitted (missing --execute flag)
  2  — invalid extra name
  3  — pip download failed (with --execute)
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from dataclasses import dataclass
from typing import Dict, List

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

